# ──────────────────────────────────────────────────────────────
# Arrowlink Global Procurement — Environment Configuration
# Copy this file to `.env.local` and fill in the values you have.
# Every integration is optional: leave a value blank and that
# script simply won't load. The site works fully without any of them.
# ──────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://arrowlinkprocurement.com

# ── Booking ────────────────────────────────────────────────────
# Your Calendly scheduling URL, e.g. https://calendly.com/arrowlink/consultation
NEXT_PUBLIC_CALENDLY_URL=

# ── Analytics & Tag Management ─────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Tag Manager container ID (GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=
# LinkedIn Insight Tag Partner ID (numeric)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_ID=

# ── HubSpot ────────────────────────────────────────────────────
# HubSpot account / portal ID (numeric) — loads the tracking + forms script
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
# HubSpot Forms region (e.g. na1, eu1) — optional, used by embedded forms
NEXT_PUBLIC_HUBSPOT_REGION=na1
# HubSpot form GUID for the lead/onboarding form (optional embed)
NEXT_PUBLIC_HUBSPOT_LEAD_FORM_ID=

# ── Lead capture (server-side) ─────────────────────────────────
# Where contact/onboarding submissions are emailed or forwarded.
# Used by the /api/lead route. If using HubSpot Forms API:
HUBSPOT_PRIVATE_APP_TOKEN=
# Fallback notification email (if you wire an email provider such as Resend)
LEAD_NOTIFICATION_EMAIL=info@arrowlinkprocurement.com
RESEND_API_KEY=
